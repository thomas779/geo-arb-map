{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "number",
      "const": 1
    },
    "entity_type": {
      "type": "string",
      "const": "change_proposal"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9:_-]*$"
    },
    "signal_ids": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9:_-]*$"
      }
    },
    "target_entity_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9:_-]*$"
    },
    "action": {
      "type": "string",
      "enum": [
        "create",
        "update",
        "retire"
      ]
    },
    "effective_from": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "operations": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "op": {
            "type": "string",
            "enum": [
              "add",
              "replace",
              "remove"
            ]
          },
          "path": {
            "type": "string",
            "pattern": "^\\/"
          },
          "value": {}
        },
        "required": [
          "op",
          "path"
        ],
        "additionalProperties": false
      }
    },
    "source_refs": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9:_-]*$"
          },
          "supports_fields": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^\\/"
            }
          },
          "note": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "source_id",
          "supports_fields"
        ],
        "additionalProperties": false
      }
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "review_status": {
      "type": "string",
      "enum": [
        "draft",
        "evidence_verified",
        "approved",
        "rejected"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    }
  },
  "required": [
    "schema_version",
    "entity_type",
    "id",
    "signal_ids",
    "target_entity_id",
    "action",
    "effective_from",
    "operations",
    "source_refs",
    "rationale",
    "review_status",
    "created_at"
  ],
  "additionalProperties": false,
  "$id": "https://atlas.thomphreys.com/data/schemas/change_proposal-v1.schema.json",
  "title": "Flag Paths change proposal v1"
}
