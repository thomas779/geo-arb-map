{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "number",
      "const": 1
    },
    "entity_type": {
      "type": "string",
      "const": "source"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9:_-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "publisher": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "enum": [
        "primary_law",
        "official_gazette",
        "official_guidance",
        "treaty",
        "court_decision",
        "secondary_legal",
        "discovery"
      ]
    },
    "jurisdictions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^\\d{3}$"
      }
    },
    "language": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 2
        },
        {
          "type": "null"
        }
      ]
    },
    "published_at": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "last_checked": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "monitoring": {
      "type": "object",
      "properties": {
        "source_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9:_-]*$"
        },
        "method": {
          "type": "string",
          "enum": [
            "api",
            "http",
            "rss",
            "email",
            "telegram",
            "youtube"
          ]
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "planned",
            "paused"
          ]
        }
      },
      "required": [
        "source_id",
        "method",
        "url",
        "status"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "schema_version",
    "entity_type",
    "id",
    "title",
    "url",
    "publisher",
    "source_type",
    "jurisdictions",
    "language",
    "published_at",
    "last_checked"
  ],
  "additionalProperties": false,
  "$id": "https://atlas.thomphreys.com/data/schemas/source-v1.schema.json",
  "title": "Flag Paths source v1"
}
