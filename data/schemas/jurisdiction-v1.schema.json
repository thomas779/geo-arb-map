{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "number",
      "const": 1
    },
    "entity_type": {
      "type": "string",
      "const": "jurisdiction"
    },
    "id": {
      "type": "string",
      "pattern": "^jurisdiction:\\d{3}$"
    },
    "jurisdiction": {
      "type": "object",
      "properties": {
        "iso_n3": {
          "type": "string",
          "pattern": "^\\d{3}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "sovereign",
            "territory",
            "special"
          ]
        }
      },
      "required": [
        "iso_n3",
        "name",
        "type"
      ],
      "additionalProperties": false
    },
    "review": {
      "type": "object",
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "unchecked",
            "legacy",
            "pending",
            "partial",
            "reviewed"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "last_checked": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            {
              "type": "null"
            }
          ]
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "state",
        "confidence",
        "last_checked"
      ],
      "additionalProperties": false
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9:_-]*$"
          },
          "mode": {
            "type": "string",
            "enum": [
              "ancestry",
              "naturalization",
              "birth",
              "investment"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "inactive",
              "verified_negative",
              "pending_verification"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "effective": {
            "type": "object",
            "properties": {
              "from": {
                "anyOf": [
                  {
                    "type": "string",
                    "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "to": {
                "anyOf": [
                  {
                    "type": "string",
                    "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "supersedes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9:_-]*$"
                }
              }
            },
            "required": [
              "from",
              "to",
              "supersedes"
            ],
            "additionalProperties": false
          },
          "review": {
            "type": "object",
            "properties": {
              "state": {
                "type": "string",
                "enum": [
                  "unchecked",
                  "legacy",
                  "pending",
                  "partial",
                  "reviewed"
                ]
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ]
              },
              "last_checked": {
                "anyOf": [
                  {
                    "type": "string",
                    "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "note": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "state",
              "confidence",
              "last_checked"
            ],
            "additionalProperties": false
          },
          "variants": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9:_-]*$"
                },
                "label": {
                  "type": "string",
                  "minLength": 1
                },
                "outcome": {
                  "type": "string",
                  "enum": [
                    "citizenship",
                    "residence",
                    "permanent_residence",
                    "work"
                  ]
                },
                "allocation": {
                  "type": "string",
                  "enum": [
                    "right",
                    "discretionary",
                    "ballot",
                    "quota_queue"
                  ]
                },
                "eligibility": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "field": {
                        "type": "string",
                        "pattern": "^[a-z][a-z0-9_.]*$"
                      },
                      "operator": {
                        "type": "string",
                        "enum": [
                          "eq",
                          "neq",
                          "in",
                          "not_in",
                          "gte",
                          "lte",
                          "exists"
                        ]
                      },
                      "value": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "number"
                          },
                          {
                            "type": "boolean"
                          },
                          {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          },
                          {
                            "type": "array",
                            "items": {
                              "type": "number"
                            }
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "unit": {
                        "type": "string",
                        "enum": [
                          "months",
                          "years",
                          "days",
                          "count"
                        ]
                      },
                      "note": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "required": [
                      "field",
                      "operator",
                      "value"
                    ],
                    "additionalProperties": false
                  }
                },
                "milestones": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "status": {
                        "type": "string",
                        "pattern": "^[a-z][a-z0-9_]*$"
                      },
                      "minimum_months": {
                        "anyOf": [
                          {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 9007199254740991
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "note": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "required": [
                      "status",
                      "minimum_months"
                    ],
                    "additionalProperties": false
                  }
                },
                "timeline": {
                  "type": "object",
                  "properties": {
                    "eligibility_minimum_months": {
                      "anyOf": [
                        {
                          "type": "integer",
                          "minimum": 0,
                          "maximum": 9007199254740991
                        },
                        {
                          "type": "null"
                        }
                      ]
                    },
                    "processing_typical_months": {
                      "anyOf": [
                        {
                          "type": "integer",
                          "exclusiveMinimum": 0,
                          "maximum": 9007199254740991
                        },
                        {
                          "type": "null"
                        }
                      ]
                    },
                    "confidence": {
                      "type": "string",
                      "enum": [
                        "high",
                        "medium",
                        "low"
                      ]
                    },
                    "note": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "eligibility_minimum_months",
                    "processing_typical_months",
                    "confidence"
                  ],
                  "additionalProperties": false
                },
                "source_refs": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "source_id": {
                        "type": "string",
                        "pattern": "^[a-z0-9][a-z0-9:_-]*$"
                      },
                      "supports_fields": {
                        "minItems": 1,
                        "type": "array",
                        "items": {
                          "type": "string",
                          "pattern": "^\\/"
                        }
                      },
                      "note": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "required": [
                      "source_id",
                      "supports_fields"
                    ],
                    "additionalProperties": false
                  }
                }
              },
              "required": [
                "id",
                "label",
                "outcome",
                "allocation",
                "eligibility",
                "milestones",
                "timeline",
                "source_refs"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "id",
          "mode",
          "status",
          "title",
          "summary",
          "effective",
          "review",
          "variants"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "schema_version",
    "entity_type",
    "id",
    "jurisdiction",
    "review",
    "routes"
  ],
  "additionalProperties": false,
  "$id": "https://atlas.thomphreys.com/data/schemas/jurisdiction-v1.schema.json",
  "title": "Flag Paths jurisdiction v1"
}
