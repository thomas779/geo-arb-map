{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "number",
      "const": 1
    },
    "entity_type": {
      "type": "string",
      "const": "arrangement"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9:_-]*$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "regional",
        "bilateral",
        "heritage"
      ]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "pending"
      ]
    },
    "directionality": {
      "type": "string",
      "enum": [
        "symmetric",
        "asymmetric"
      ]
    },
    "participants": {
      "type": "object",
      "properties": {
        "members": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\d{3}$"
          }
        },
        "former_members": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\d{3}$"
          }
        },
        "destinations": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\d{3}$"
          }
        },
        "beneficiaries": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\d{3}$"
          }
        },
        "beneficiaries_note": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "members",
        "former_members",
        "destinations",
        "beneficiaries"
      ],
      "additionalProperties": false
    },
    "display": {
      "type": "object",
      "properties": {
        "category": {
          "type": "string",
          "enum": [
            "full",
            "partial",
            "hub_spoke",
            "one_way",
            "closed",
            "proto"
          ]
        },
        "strength": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "color": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        }
      },
      "required": [
        "category",
        "strength",
        "color"
      ],
      "additionalProperties": false
    },
    "rights_by_status": {
      "type": "object",
      "properties": {
        "temporary_residence": {
          "type": "string"
        },
        "permanent_residence": {
          "type": "string"
        },
        "citizenship": {
          "type": "string"
        }
      },
      "required": [
        "temporary_residence",
        "permanent_residence",
        "citizenship"
      ],
      "additionalProperties": false
    },
    "pathways": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9:_-]*$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "outcome": {
            "type": "string",
            "enum": [
              "citizenship",
              "residence",
              "permanent_residence",
              "work"
            ]
          },
          "allocation": {
            "type": "string",
            "enum": [
              "right",
              "discretionary",
              "ballot",
              "quota_queue"
            ]
          },
          "eligibility": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_.]*$"
                },
                "operator": {
                  "type": "string",
                  "enum": [
                    "eq",
                    "neq",
                    "in",
                    "not_in",
                    "gte",
                    "lte",
                    "exists"
                  ]
                },
                "value": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "number"
                    },
                    {
                      "type": "boolean"
                    },
                    {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    {
                      "type": "array",
                      "items": {
                        "type": "number"
                      }
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "unit": {
                  "type": "string",
                  "enum": [
                    "months",
                    "years",
                    "days",
                    "count"
                  ]
                },
                "note": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "field",
                "operator",
                "value"
              ],
              "additionalProperties": false
            }
          },
          "milestones": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_]*$"
                },
                "minimum_months": {
                  "anyOf": [
                    {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "note": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "status",
                "minimum_months"
              ],
              "additionalProperties": false
            }
          },
          "timeline": {
            "type": "object",
            "properties": {
              "eligibility_minimum_months": {
                "anyOf": [
                  {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "processing_typical_months": {
                "anyOf": [
                  {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ]
              },
              "note": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "eligibility_minimum_months",
              "processing_typical_months",
              "confidence"
            ],
            "additionalProperties": false
          },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "source_id": {
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9:_-]*$"
                },
                "supports_fields": {
                  "minItems": 1,
                  "type": "array",
                  "items": {
                    "type": "string",
                    "pattern": "^\\/"
                  }
                },
                "note": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "source_id",
                "supports_fields"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "id",
          "label",
          "outcome",
          "allocation",
          "eligibility",
          "milestones",
          "timeline",
          "source_refs"
        ],
        "additionalProperties": false
      }
    },
    "editorial": {
      "type": "object",
      "properties": {
        "fastest_entry": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "limits": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "review": {
      "type": "object",
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "unchecked",
            "legacy",
            "pending",
            "partial",
            "reviewed"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "last_checked": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            {
              "type": "null"
            }
          ]
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "state",
        "confidence",
        "last_checked"
      ],
      "additionalProperties": false
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9:_-]*$"
          },
          "supports_fields": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^\\/"
            }
          },
          "note": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "source_id",
          "supports_fields"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "schema_version",
    "entity_type",
    "id",
    "kind",
    "name",
    "status",
    "directionality",
    "participants",
    "display",
    "rights_by_status",
    "pathways",
    "editorial",
    "review",
    "source_refs"
  ],
  "additionalProperties": false,
  "$id": "https://atlas.thomphreys.com/data/schemas/arrangement-v1.schema.json",
  "title": "Flag Paths arrangement v1"
}
