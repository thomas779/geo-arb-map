{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "flag-paths-web",
  "compatibility_date": "2026-07-19",
  "workers_dev": true,
  "preview_urls": false,
  "assets": {
    "directory": "./dist",
    "not_found_handling": "none"
  },
  "routes": [
    {
      "pattern": "atlas.thomphreys.com/*",
      "zone_name": "thomphreys.com"
    }
  ]
}
