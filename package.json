{
  "name": "geo-arb-map",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "bun",
  "scripts": {
    "dev": "vite",
    "build": "tsc && tsc -p monitor/cloudflare/tsconfig.json && bun test && vite build",
    "deploy:web": "bun run build && bun scripts/deploy_web.ts",
    "data:citizenship": "bun scripts/build_citizenship_routes.js",
    "data:build": "bun scripts/build_data_release.ts",
    "data:db": "bun scripts/build_canonical_database.ts",
    "data:review": "bun scripts/build_data_review.ts",
    "data:timelines": "bun scripts/build_timeline_rules.js",
    "data:edges": "bun run data:timelines && bun scripts/build_edges.js",
    "monitor:collect": "bun monitor/collectors/run.ts",
    "monitor:email:dispatch": "bun monitor/collectors/github-dispatch.ts",
    "monitor:email:dev": "wrangler dev --config monitor/cloudflare/wrangler.jsonc",
    "monitor:email:deploy": "wrangler deploy --config monitor/cloudflare/wrangler.jsonc",
    "monitor:triage": "bun monitor/triage/triage.ts",
    "monitor:draft": "bun monitor/triage/open-issues.ts --dry-run",
    "monitor:open": "bun monitor/triage/open-issues.ts --apply",
    "monitor:telegram": "bun monitor/publish/telegram.ts",
    "monitor:test": "bun test tests/monitor.test.ts",
    "preview": "vite preview",
    "test": "bun test"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "i18n-iso-countries": "7.14.0",
    "lucide-react": "^1.24.0",
    "postal-mime": "^2.7.5",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "topojson-client": "^3.1.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260717.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/bun": "^1.3.14",
    "@types/d3": "^7.4.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/topojson-client": "^3.1.4",
    "@types/topojson-specification": "^1.0.4",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.5.3",
    "vite": "^8.1.4",
    "wrangler": "^4.112.0",
    "zod": "^4.3.6"
  }
}
